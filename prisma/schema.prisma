generator client {
  provider = "prisma-client-js" // para Prisma v7 sem ESM
}

datasource db {
  provider = "postgresql"
}

model Task {
  id          String   @id @default(uuid()) // agora é string com UUID
  title       String
  description String?  // novo campo
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}